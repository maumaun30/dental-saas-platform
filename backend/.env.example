# Backend configuration. Copy to .env and adjust as needed.
PORT=4000

# IMPORTANT: set a long random value in production.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins, or * for any.
CORS_ORIGIN=*

# Where the JSON database is written.
# DB_FILE=./data/db.json

# Seed a demo account on first boot (set to false to disable).
SEED_DEMO_USER=true
DEMO_EMAIL=dentist@demo.com
DEMO_PASSWORD=demo1234
DEMO_NAME=Dr. Demo
DEMO_PRACTICE=Bright Smile Dental
