{
  "name": "dental-saas-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Dental SaaS Platform — OHIF Dental Mode viewer + Node backend.",
  "scripts": {
    "install:backend": "npm --prefix backend install",
    "install:viewer": "yarn --cwd Viewers install",
    "start:backend": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:viewer": "yarn --cwd Viewers workspace @ohif/app dev",
    "dev": "concurrently -n api,web -c blue,green \"npm:start:backend\" \"npm:dev:viewer\"",
    "test": "npm --prefix backend test"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
